OUTPUT_FILE="report.txt"

# Функция: показать все .txt файлы
show_txt_files() {
    echo "ДОСТУПНЫЕ ТЕКСТОВЫЕ ФАЙЛЫ (.txt)" # Найти все .txt файлы в текущей папке
    mapfile -t files < <(find . -maxdepth 1 -type f -name "*.txt" ! -name "report.txt" | sed 's|\./||' | sort)
    if [[ ${#files[@]} -eq 0 ]]; then
        echo "Нет .txt файлов в текущей папке!"
        echo "Поместите .txt файл в папку /mnt/t/laba6 и запустите скрипт снова"
        exit 1
    fi
    
    # Показать файлы с номерами
    for i in "${!files[@]}"; do
        lines=$(wc -l < "${files[$i]}")
        echo "$((i+1)). ${files[$i]} (строк: $lines)"
    done
}

# Функция: показать все файлы
show_all_files() {
    echo "ВСЕ ФАЙЛЫ В ТЕКУЩЕЙ ПАПКЕ"    
    mapfile -t all_files < <(find . -maxdepth 1 -type f ! -name "report.txt" ! -name "*.sh" | sed 's|\./||' | sort)
    if [[ ${#all_files[@]} -eq 0 ]]; then
        echo "Нет файлов в текущей папке!"
        exit 1
    fi
    
    for i in "${!all_files[@]}"; do
        echo "  $((i+1)). ${all_files[$i]}"
    done
}

# Функция: анализ файла
analyze_file() {
    local INPUT_FILE="$1"
    echo "Анализируем файл: $INPUT_FILE"    
    # Проверка существования файла
    if [[ ! -f "$INPUT_FILE" ]]; then
        echo "Ошибка: файл '$INPUT_FILE' не найден"
        return 1
    fi
  
    #Статистика
    LINES=$(wc -l < "$INPUT_FILE" 2>/dev/null || echo "0")
    WORDS=$(wc -w < "$INPUT_FILE" 2>/dev/null || echo "0")
    CHARS=$(wc -c < "$INPUT_FILE" 2>/dev/null || echo "0")
    
    # Запись в report.txt
    {
        echo "ОТЧЕТ О АНАЛИЗЕ ФАЙЛА"
        echo "Имя файла: $INPUT_FILE"
        echo "Дата анализа: $(date '+%Y-%m-%d %H:%M:%S')"
        echo "СТАТИСТИКА"
        echo ""
        printf "Количество строк:   %10d\n" "$LINES"
        printf "Количество слов:    %10d\n" "$WORDS"
        printf "Количество символов: %10d\n" "$CHARS"
    } > "$OUTPUT_FILE"
    
    echo "Готово! Отчет сохранен в $OUTPUT_FILE"
    echo ""
    echo "Содержимое отчета:"
    cat "$OUTPUT_FILE"
    
    return 0
}

# Функция: показать результат
show_result() {
    echo ""
    echo "ЧТО ДЕЛАЕМ ДАЛЕЕ?"
    echo "1. Анализировать другой файл"
    echo "2. Показать отчет (report.txt)"
    echo "3. Выйти"
    echo -n "Выберите (1-3): "
    read -r choice
    
    case $choice in
        1) main ;;
        2) cat "$OUTPUT_FILE"; show_result ;;
        3) echo "До свидания!"; exit 0 ;;
        *) echo "Неверный выбор"; show_result ;;
    esac
}

# Главное меню
main() {
    clear 2>/dev/null || echo ""
    echo "ГЕНЕРАТОР ОТЧЕТОВ"
    echo "Выберите режим работы:"
    echo "1. Показать только .txt файлы"
    echo "2. Показать все файлы"
    echo "3. Указать путь к файлу вручную"
    echo "4. Выйти"
    echo -n "Ваш выбор (1-4):"
    read -r mode
    
    case $mode in
        1)
            show_txt_files
            echo ""
            echo -n "Выберите номер файла для анализа: "
            read -r file_num
            mapfile -t files < <(find . -maxdepth 1 -type f -name "*.txt" ! -name "report.txt" | sed 's|\./||' | sort)
            if [[ "$file_num" =~ ^[0-9]+$ ]] && [ "$file_num" -ge 1 ] && [ "$file_num" -le "${#files[@]}" ]; then
                analyze_file "${files[$((file_num-1))]}"
                show_result
            else
                echo "Неверный номер файла!"
                sleep 2
                main
            fi
            ;;
        2)
            show_all_files
            echo ""
            echo -n "Выберите номер файла для анализа: "
            read -r file_num
            mapfile -t all_files < <(find . -maxdepth 1 -type f ! -name "report.txt" ! -name "*.sh" | sed 's|\./||' | sort)
            if [[ "$file_num" =~ ^[0-9]+$ ]] && [ "$file_num" -ge 1 ] && [ "$file_num" -le "${#all_files[@]}" ]; then
                analyze_file "${all_files[$((file_num-1))]}"
                show_result
            else
                echo "Неверный номер файла!"
                sleep 2
                main
            fi
            ;;
        3)
            echo -n "Введите путь к файлу: "
            read -r custom_path
            if [[ -f "$custom_path" ]]; then
                analyze_file "$custom_path"
                show_result
            else
                echo "Файл не найден: $custom_path"
                sleep 2
                main
            fi
            ;;
        4)
            echo "До свидания!"
            exit 0
            ;;
        *)
            echo "Неверный выбор!"
            sleep 1
            main
            ;;
    esac
}

# Запуск
main

